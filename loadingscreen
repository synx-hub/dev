local function setDotActive(index)
	for i, dot in ipairs(stageDots) do
		if i < index then
			TweenService:Create(dot, TweenInfo.new(0.3), { BackgroundColor3 = Color3.fromRGB(76, 175, 80) }):Play()
		elseif i == index then
			TweenService:Create(dot, TweenInfo.new(0.3), { BackgroundColor3 = Color3.fromRGB(180, 255, 100) }):Play()
			TweenService:Create(dot, TweenInfo.new(0.6, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true), {
				BackgroundColor3 = Color3.fromRGB(100, 200, 60)
			}):Play()
		else
			TweenService:Create(dot, TweenInfo.new(0.3), { BackgroundColor3 = Color3.fromRGB(30, 70, 30) }):Play()
		end
	end
end

