-------------------------------------------------
-- FLOATING PARTICLES (emojis drifting upward)
-------------------------------------------------
local PARTICLE_EMOJIS = { "🌱", "🌿", "🍃", "🌾", "🌻", "🌷", "✨", "🍀" }

local function createParticle()
	local p = Instance.new("TextLabel")
	p.Size = UDim2.fromOffset(28, 28)
	p.BackgroundTransparency = 1
	p.Text = PARTICLE_EMOJIS[math.random(1, #PARTICLE_EMOJIS)]
	p.TextScaled = true
	p.TextTransparency = math.random(20, 50) / 100
	p.ZIndex = 2
	p.Position = UDim2.new(math.random(5, 95) / 100, 0, 1.05, 0)
	p.Parent = backdrop

	local driftX = (math.random(-8, 8)) / 100
	local targetPos = UDim2.new(
		p.Position.X.Scale + driftX,
		0, -0.08, 0
	)
	local duration = math.random(60, 110) / 10

	local tween = TweenService:Create(p, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
		Position = targetPos,
		TextTransparency = 1,
	})
	tween:Play()
	tween.Completed:Connect(function()
		p:Destroy()
	end)
end

-- Spawn particles continuously
task.spawn(function()
	while backdrop and backdrop.Parent do
		createParticle()
		task.wait(math.random(3, 7) / 10)
	end
end)

-- Burst of particles on start
for i = 1, 14 do
	task.delay(i * 0.08, createParticle)
