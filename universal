--==================================================
-- SAFE COPY FUNCTION
--==================================================
local function CopyText(text)
    local success = false
    pcall(function()
        -- Direct assignment checks to prevent global environment errors
        local setclip = move_to_top or setclipboard or toclipboard or (Clipboard and Clipboard.set)
        if setclipboard then
            setclipboard(text)
            success = true
        elseif toclipboard then
            toclipboard(text)
            success = true
        elseif Clipboard and Clipboard.set then
            Clipboard.set(text)
            success = true
        end
    end)
    return success
end

