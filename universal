-- BUTTON STATES
local discordDone = false
local youtubeDone = false

local function UnlockScript()
    TweenService:Create(Card, TweenInfo.new(0.45, Enum.EasingStyle.BackIn), {
        Position = UDim2.new(0.5,-165,1.5,0),
        BackgroundTransparency = 1
    }):Play()

    TweenService:Create(Backdrop, TweenInfo.new(0.45), {
        BackgroundTransparency = 1
    }):Play()

    TweenService:Create(Blur, TweenInfo.new(0.45), {
        Size = 0
    }):Play()

    task.wait(0.45)

    ScreenGui:Destroy()

    if Blur then
        Blur:Destroy()
    end
end

local function CheckUnlock()
    if discordDone and youtubeDone then
        task.wait(1)
        UnlockScript()
    end
end

